{
  "permissions": {
    "allow": [
      "Bash(node --check *)",
      "Bash(open *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git fetch *)",
      "Bash(git push)",
      "Bash(plutil -lint *)",
      "Bash(dotnet list *)",
      "Bash(npm root *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git branch -D*)",
      "Bash(git branch --delete*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git filter-branch*)"
    ]
  }
}
